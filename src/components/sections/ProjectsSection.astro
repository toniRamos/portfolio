---
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const portfolioScreenshot = "/images/projects/portfolio-screenshot.png";
const videoStoreScreenshot = "/images/projects/video-store-screenshot.png";
const planningPokerScreenshot = "/images/projects/planning-poker.png";
const chessScreenshot = "/images/projects/chess.png";
const factorioLikeScreenshot = "/images/projects/factorio-like.png";
const infiniteDarkLogo = "/images/projects/principal-logo-infinite-dark.png";
const devApplicationsLogo = "/images/projects/logoDevApplications.png";
---

<section id="projects" class="projects">
	<div class="container">
		<div class="section-header reveal-element">
			<h2 class="section-title">
				<span class="section-number">{t('projects.number')}</span>
				{t('projects.title')}
			</h2>
		</div>
		<div class="projects-grid">

			<div class="project-card reveal-stagger">
				<a href="https://devapplications.xyz/" target="_blank" rel="noopener noreferrer" class="project-image">
					<img
						src={devApplicationsLogo}
						alt={t('projects.devApplications.title')}
					/>
				</a>
				<div class="project-content">
					<p class="project-overline">{t('projects.personal')}</p>
					<h3 class="project-title">
						<a href="https://devapplications.xyz/" target="_blank" rel="noopener noreferrer">
							{t('projects.devApplications.title')}
						</a>
					</h3>
					<div class="project-description">
						<p>{t('projects.devApplications.description')}</p>
					</div>
					<div class="project-technologies">
						{t('projects.devApplications.tech').map((tech, index) => (
							<span class="tech-tag" key={index}>{tech}</span>
						))}
					</div>
					<div class="project-links">
						<a href="https://devapplications.xyz/" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Abrir DevApplications en nueva pestaña">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
						</a>
					</div>
				</div>
			</div>

			<div class="project-card reveal-stagger">
				<a href="https://play.google.com/store/apps/details?id=com.devapplications.infiniteDark" target="_blank" rel="noopener noreferrer" class="project-image">
					<img
						src={infiniteDarkLogo}
						alt={t('projects.infiniteDark.title')}
					/>
				</a>
				<div class="project-content">
					<p class="project-overline">{t('projects.personal')}</p>
					<h3 class="project-title">
						<a href="https://play.google.com/store/apps/details?id=com.devapplications.infiniteDark" target="_blank" rel="noopener noreferrer">
							{t('projects.infiniteDark.title')}
						</a>
					</h3>
					<div class="project-description">
						<p>{t('projects.infiniteDark.description')}</p>
					</div>
					<div class="project-technologies">
						{t('projects.infiniteDark.tech').map((tech, index) => (
							<span class="tech-tag" key={index}>{tech}</span>
						))}
					</div>
					<div class="project-links">
						<a href="https://play.google.com/store/apps/details?id=com.devapplications.infiniteDark" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Abrir Infinite Dark en Google Play">
							<img
								src="/images/icons/google-play-badge-logo.svg"
								alt="Google Play"
								class="google-play-badge"
								width="22"
								height="22"
								loading="lazy"
							/>
						</a>
					</div>
				</div>
			</div>

			<div class="project-card reveal-stagger">
				<a href="https://toniramos.github.io/factorio-like/" target="_blank" rel="noopener noreferrer" class="project-image">
					<img 
						src={factorioLikeScreenshot} 
						alt={t('projects.factorioLike.title')}
					/>
				</a>
				<div class="project-content">
					<p class="project-overline">{t('projects.personal')}</p>
					<h3 class="project-title">
						<a href="https://toniramos.github.io/factorio-like/" target="_blank" rel="noopener noreferrer">
							{t('projects.factorioLike.title')}
						</a>
					</h3>
					<div class="project-description">
						<p>{t('projects.factorioLike.description')}</p>
					</div>
					<div class="project-technologies">
						{t('projects.factorioLike.tech').map((tech, index) => (
							<span class="tech-tag" key={index}>{tech}</span>
						))}
					</div>
					<div class="project-links">
						<a href="https://toniramos.github.io/factorio-like/" target="_blank" rel="noopener noreferrer" class="project-link">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
						</a>
						<a href="https://github.com/toniRamos/factorio-like" target="_blank" rel="noopener noreferrer" class="project-link">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
						</a>
					</div>
				</div>
			</div>

					<div class="project-card chess-layout reveal-stagger">
						<a href="https://github.com/toniRamos/chess" target="_blank" rel="noopener noreferrer" class="project-image">
							<img 
								src={chessScreenshot} 
								alt={t('projects.chess.title')}
							/>
						</a>
						<div class="project-content">
							<p class="project-overline">{t('projects.personal')}</p>
							<h3 class="project-title">
								<a href="https://github.com/toniRamos/chess" target="_blank" rel="noopener noreferrer">
									{t('projects.chess.title')}
								</a>
							</h3>
							<div class="project-description">
								<p>{t('projects.chess.description')}</p>
							</div>
							<div class="project-technologies">
								{t('projects.chess.tech').map((tech, index) => (
									<span class="tech-tag" key={index}>{tech}</span>
								))}
							</div>
					<div class="project-links">
						<a href="https://github.com/toniRamos/chess" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Abrir Chess en GitHub">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
						</a>
					</div>
						</div>
					</div>

			<div class="project-card reveal-stagger">
				<a href="https://github.com/toniRamos/planning-poker" target="_blank" rel="noopener noreferrer" class="project-image">
					<img 
						src={planningPokerScreenshot} 
						alt={t('projects.planningPoker.title')}
					/>
				</a>
				<div class="project-content">
					<p class="project-overline">{t('projects.personal')}</p>
					<h3 class="project-title">
						<a href="https://github.com/toniRamos/planning-poker" target="_blank" rel="noopener noreferrer">
							{t('projects.planningPoker.title')}
						</a>
					</h3>
					<div class="project-description">
						<p>{t('projects.planningPoker.description')}</p>
					</div>
					<div class="project-technologies">
						{t('projects.planningPoker.tech').map((tech, index) => (
							<span class="tech-tag" key={index}>{tech}</span>
						))}
					</div>
					<div class="project-links">
						<a href="https://github.com/toniRamos/planning-poker" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Abrir Planning Poker en GitHub">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
						</a>
					</div>
				</div>
			</div>

			<div class="project-card reveal-stagger">
				<a href="https://github.com/toniRamos/portfolio" target="_blank" rel="noopener noreferrer" class="project-image">
					<img 
						src={portfolioScreenshot} 
						alt={t('projects.portfolio.title')}
					/>
				</a>
				<div class="project-content">
					<p class="project-overline">{t('projects.featured')}</p>
					<h3 class="project-title">
						<a href="https://github.com/toniRamos/portfolio" target="_blank" rel="noopener noreferrer">
							{t('projects.portfolio.title')}
						</a>
					</h3>
					<div class="project-description">
						<p>{t('projects.portfolio.description')}</p>
					</div>
					<div class="project-technologies">
						{t('projects.portfolio.tech').map((tech, index) => (
							<span class="tech-tag" key={index}>{tech}</span>
						))}
					</div>
					<div class="project-links">
						<a href="https://github.com/toniRamos/portfolio" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Abrir Portfolio en GitHub">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
						</a>
					</div>
				</div>
			</div>

			<div class="project-card reveal-stagger">
				<a href="https://github.com/toniRamos/video-store" target="_blank" rel="noopener noreferrer" class="project-image">
					<img 
						src={videoStoreScreenshot} 
						alt={t('projects.videoStore.title')}
					/>
				</a>
				<div class="project-content">
					<p class="project-overline">{t('projects.personal')}</p>
					<h3 class="project-title">
						<a href="https://github.com/toniRamos/video-store" target="_blank" rel="noopener noreferrer">
							{t('projects.videoStore.title')}
						</a>
					</h3>
					<div class="project-description">
						<p>{t('projects.videoStore.description')}</p>
					</div>
					<div class="project-technologies">
						{t('projects.videoStore.tech').map((tech, index) => (
							<span class="tech-tag" key={index}>{tech}</span>
						))}
					</div>
					<div class="project-links">
						<a href="https://github.com/toniRamos/video-store" target="_blank" rel="noopener noreferrer" class="project-link" aria-label="Abrir Video Store en GitHub">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
